# StudyMate Environment Variables

# Database Configuration
POSTGRES_URI=postgresql://studymate:studymate_password@localhost:5432/studymate
REDIS_URL=redis://localhost:6379

# Vector Database Configuration
VECTOR_DB_TYPE=weaviate  # or chromadb
WEAVIATE_URL=https://your-weaviate-cluster.weaviate.network
WEAVIATE_API_KEY=your_weaviate_api_key
CHROMADB_PERSIST_DIRECTORY=./chromadb

# LLM Configuration
DEFAULT_LLM=claude  # claude, openai, gemini, or local

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Anthropic Claude Configuration  
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# Local LLM Configuration (Ollama)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b

# Embedding Configuration
EMBEDDING_MODEL=openai  # openai or local
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
LOCAL_EMBEDDING_MODEL=all-mpnet-base-v2

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# Application Configuration
DEBUG=true
MAX_FILE_SIZE=52428800  # 50MB in bytes
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000